---
import '@atfedi/shared/styles/tokens.css';
import '@atfedi/shared/styles/base.css';
import '@atfedi/shared/styles/components.css';
import '../styles/blog.css';

// Same fonts as the catalog — Latin first, the CJK subsets load by
// unicode-range only when a page actually has kana·kanji / hangul.
import '@fontsource-variable/source-sans-3';
import '@fontsource/biz-udpgothic/japanese-400.css';
import '@fontsource/biz-udpgothic/japanese-700.css';
import '@fontsource/nanum-gothic/korean-400.css';
import '@fontsource/nanum-gothic/korean-700.css';

import { locales, localeNames } from '../locales';

interface Props {
  lang: string;
  title: string;
  description?: string;
  // Locales this page exists in. Post pages pass the post's translations;
  // the per-language home pages leave it unset → all locales.
  langs?: readonly string[];
  // Set by the live preview — shows the top band and marks the page
  // noindex. Ordinary blog pages leave it unset.
  banner?: string;
  // Override the language switcher's targets. The preview points them
  // under /v/preview/{ref}/-/ ; ordinary pages use the path-based default.
  langHref?: (lang: string) => string;
}

const { lang, title, description, langs, banner, langHref } = Astro.props;

// The quiet door to the support page — the page itself explains why,
// and holds the per-region donation links.
const supportLabel: Record<string, string> = { en: 'Support', ja: '応援', ko: '응원' };

// The same path under another language — for the switcher.
const rest = Astro.url.pathname.replace(/^\/(en|ja|ko)/, '') || '/';
const switchLangs = langs ?? locales;
const hrefFor = langHref ?? ((l: string) => `/${l}${rest}`);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {banner && <meta name="robots" content="noindex, nofollow" />}
  </head>
  <body>
    {banner && <div class="preview-banner">{banner}</div>}
    <header class="site-header">
      <a class="site-brand" href={`/${lang}/`}>
        <svg class="brand-mark" viewBox="0 0 32 32" aria-hidden="true">
          <rect width="32" height="32" rx="7" fill="var(--color-text)" />
          <g
            transform="translate(4 4)"
            fill="none"
            stroke="var(--color-bg)"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <!-- Teeline shorthand "b" from teeline-online by Gonzo Engineering (MIT) — credit in README.md -->
            <path d="M13.259 2.607c-3.521 -1.645 -10.964 16.136 -3.672 18.691c3.577 1.253 9.84 -3.6 7.344 -7.379c-1.238 -1.873 -5.057 -2.323 -7.072 -1.919c-0.835 0.167 -1.535 0.521 -2.273 0.926c-0.359 0.197 -1.234 1.073 -0.952 0.776" />
          </g>
        </svg>
        atfedi.de blog
      </a>
      <nav class="site-nav" aria-label="Sections">
        <a href={`https://${lang}.atfedi.de`}>tools ↗</a>
      </nav>
      <nav class="lang-switch" aria-label="Language">
        {
          switchLangs.map((l) => (
            <a href={hrefFor(l)} aria-current={l === lang ? 'true' : undefined}>
              {localeNames[l]}
            </a>
          ))
        }
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p>atfedi.de — an open catalog of fediverse tools.</p>
        <div class="footer-links">
          <a href={`/${lang}/support/`}>{supportLabel[lang] ?? 'Support'}</a>
          <a href="https://github.com/f3liz-casa/atfedi-de">GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
