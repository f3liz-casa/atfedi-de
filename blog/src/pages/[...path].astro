---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

// One route for every post. The post's id is its path:
//   en/good-tools → /en/good-tools/   ja/... → /ja/...   v/... → /v/...
export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { path: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Everyday posts carry their language in the first path segment;
// dev posts (/v/...) are English.
const seg = post.id.split('/')[0];
const lang = seg === 'ja' || seg === 'ko' ? seg : 'en';
---

<Base lang={lang} title={post.data.title} description={post.data.description}>
  <div class="wrap">
    <article class="post">
      <header class="post-head">
        <h1>{post.data.title}</h1>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toISOString().slice(0, 10)}
        </time>
      </header>
      <Content />
    </article>
  </div>
</Base>
