---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

// Byline label, per locale.
const byLabel: Record<string, string> = { en: 'Written by', ja: '文', ko: '글' };

// One route per post. A post's id is {lang}/{slug}; the route splits it,
// and collects which locales share each slug — so the language switcher
// only offers translations that actually exist.
export async function getStaticPaths() {
  const posts = await getCollection('posts');

  const langsBySlug = new Map<string, string[]>();
  for (const post of posts) {
    const i = post.id.indexOf('/');
    const slug = post.id.slice(i + 1);
    (langsBySlug.get(slug) ?? langsBySlug.set(slug, []).get(slug)!).push(
      post.id.slice(0, i),
    );
  }

  return posts.map((post) => {
    const i = post.id.indexOf('/');
    const slug = post.id.slice(i + 1);
    return {
      params: { lang: post.id.slice(0, i), slug },
      props: { post, langs: langsBySlug.get(slug)! },
    };
  });
}

const { post, langs } = Astro.props;
const { Content, headings } = await render(post);
const lang = Astro.params.lang as string;

// Section links for the right rail — h2/h3 only, and only when there is
// something to navigate.
const toc = (headings ?? []).filter((h) => h.depth === 2 || h.depth === 3);
const tocLabel: Record<string, string> = { en: 'On this page', ja: '目次', ko: '목차' };

// Resolve the post's author — prefer this locale's entry, fall back to en.
const authorId = post.data.author;
const allAuthors = await getCollection('authors');
const author =
  allAuthors.find((a) => a.id === `${lang}/${authorId}`) ??
  allAuthors.find((a) => a.id === `en/${authorId}`);
if (!author) throw new Error(`Unknown author "${authorId}" in ${post.id}`);
---

<Base
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  langs={langs}
>
  <div class="wrap post-page">
    <article class="post">
      <header class="post-head">
        <h1>{post.data.title}</h1>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toISOString().slice(0, 10)}
        </time>
      </header>
      <Content />
      <footer class="post-by">
        {byLabel[lang] ?? byLabel.en}{' '}
        <a href={`/${lang}/by/${authorId}/`}>{author.data.handle}</a>
      </footer>
    </article>
    {
      toc.length > 1 && (
        <nav class="toc" aria-label={tocLabel[lang] ?? tocLabel.en}>
          <ul>
            {toc.map((heading) => (
              <li class={heading.depth === 3 ? 'toc-sub' : undefined}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }
  </div>
</Base>

<script>
  // Keep the table of contents pointing at the section being read:
  // the last heading that has scrolled past the top third of the screen.
  const toc = document.querySelector('.toc');
  if (toc !== null) {
    const links = new Map(
      [...toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')].map((a) => [
        decodeURIComponent(a.hash.slice(1)),
        a,
      ]),
    );
    const headings = [...document.querySelectorAll<HTMLElement>('.post :is(h2, h3)[id]')].filter(
      (h) => links.has(h.id),
    );
    let markedId: string | null = null;
    const update = () => {
      const line = window.innerHeight / 3;
      let activeId: string | null = null;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top > line) break;
        activeId = heading.id;
      }
      if (activeId === markedId) return;
      if (markedId !== null) links.get(markedId)?.removeAttribute('aria-current');
      if (activeId !== null) links.get(activeId)?.setAttribute('aria-current', 'location');
      markedId = activeId;
    };
    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  }
</script>
