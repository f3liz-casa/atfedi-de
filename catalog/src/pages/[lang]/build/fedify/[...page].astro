---
import { locales, type Locale } from '../../../../i18n/ui';
import { useTranslations } from '../../../../i18n/utils';
import Base from '../../../../layouts/Base.astro';
import { renderToolPage } from '../../../../lib/tool-page';
import '../../../../styles/tool-page.css';

// The fedify detail pages: a cover and four subpages, in three locales.
// Content lives in src/content/tool-pages/fedify/{page}.{lang}.md and is
// rendered by lib/tool-page (icons, cards, hero, table of contents).
const PAGES = ['index', 'roadmap', 'feels-good', 'watch-out', 'running'] as const;

export async function getStaticPaths() {
  const pages = [undefined, 'roadmap', 'feels-good', 'watch-out', 'running'];
  return locales.flatMap((lang) => pages.map((page) => ({ params: { lang, page } })));
}

const lang = Astro.params.lang as Locale;
const base = (Astro.params.page ?? 'index') as (typeof PAGES)[number];
const t = useTranslations(lang);

const sources = import.meta.glob('/src/content/tool-pages/fedify/*.md', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

const markdown = sources[`/src/content/tool-pages/fedify/${base}.${lang}.md`];
if (markdown === undefined) {
  throw new Error(`missing tool page content: fedify/${base}.${lang}.md`);
}

// Cover wears the lane · category kicker; subpages wear the tool's name.
const kicker =
  base === 'index' ? `${t('nav.build')} · ${t('cat.framework')}` : 'Fedify';

const page = renderToolPage(markdown, kicker);
const title =
  base === 'index' ? 'Fedify — atfedi.de' : `Fedify: ${page.title} — atfedi.de`;
---

<Base lang={lang} title={title} description={page.tagline}>
  <div class="tool-page-grid" style="--color-lane: var(--color-build)">
    <article class="tool-page" set:html={page.html} />
    {
      page.toc && (
        <nav class="toc" aria-label={t('toc.label')} set:html={page.toc} />
      )
    }
  </div>
</Base>

<script>
  // Keep the table of contents pointing at the section being read:
  // the last heading that has scrolled past the top third of the screen.
  // (Same behavior as the blog's post pages.)
  const toc = document.querySelector('.toc');
  if (toc !== null) {
    const links = new Map(
      [...toc.querySelectorAll<HTMLAnchorElement>('a[href^="#"]')].map((a) => [
        decodeURIComponent(a.hash.slice(1)),
        a,
      ]),
    );
    const headings = [
      ...document.querySelectorAll<HTMLElement>('.tool-page :is(h2, h3, p)[id]'),
    ].filter((h) => links.has(h.id));
    let markedId: string | null = null;
    const update = () => {
      const line = window.innerHeight / 3;
      let activeId: string | null = null;
      for (const heading of headings) {
        if (heading.getBoundingClientRect().top > line) break;
        activeId = heading.id;
      }
      if (activeId === markedId) return;
      if (markedId !== null) links.get(markedId)?.removeAttribute('aria-current');
      if (activeId !== null) links.get(activeId)?.setAttribute('aria-current', 'location');
      markedId = activeId;
    };
    document.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update, { passive: true });
    update();
  }
</script>
