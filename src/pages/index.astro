---
// Root route. The site itself lives under /en/, /ja/, /ko/.
// This page sends visitors to their language. It is fully static — detection
// runs in the browser; the <meta refresh> and the link are the no-JS fallback.
// Link-preview crawlers usually do not follow the redirect, so this page
// carries its own description and Open Graph tags.
import { ui } from '../i18n/ui';

const description = ui.en['site.tagline'];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="0; url=/en/" />
    <title>atfedi.de</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="atfedi.de" />
    <meta property="og:title" content="atfedi.de" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://atfedi.de/" />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      const supported = ['en', 'ja', 'ko'];
      const langs = navigator.languages || [navigator.language || 'en'];
      const pick = langs.map((l) => l.slice(0, 2)).find((l) => supported.includes(l)) || 'en';
      location.replace('/' + pick + '/');
    </script>
  </head>
  <body>
    <a href="/en/">Continue to atfedi.de</a>
  </body>
</html>
