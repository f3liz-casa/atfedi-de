---
// console.atfedi.de — the back room, one page.
//
// Two desks with opposite weights. The blog desk sends a post to strangers and
// can't unsend it. The kiosk desk puts a word on a card and can take it off
// again. A panel that draws them identically would be lying, so the page
// spends its only colour on the first one: the house's rust marks what leaves
// the building, and the tagging desk stays entirely in ink.
//
// The page ships no data — everything comes from /api/* on this host, which
// the Worker answers only with a publisher session.

// The family's palette, scale, and reset. No CJK faces: this room is English
// only, so the Latin variable face is the whole type budget.
import '@atfedi/shared/styles/tokens.css';
import '@atfedi/shared/styles/base.css';
import '@fontsource-variable/source-sans-3';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>console — atfedi.de</title>
  </head>
  <body>
    <div class="room">
      <header class="room-head">
        <h1 class="room-name">console</h1>
        <p class="room-who">
          <span class="mono" id="who"></span>
          <a href="/logout">sign out</a>
        </p>
      </header>

      <!-- Navigation doubles as the status board: each desk carries what's
           waiting on it, so the first glance answers "what needs me". -->
      <nav class="desks" aria-label="Desks">
        <button type="button" class="desk" data-desk="blog" aria-pressed="true">
          <span class="desk-name">blog</span>
          <span class="desk-count mono" id="count-blog"></span>
        </button>
        <button type="button" class="desk" data-desk="kiosk" aria-pressed="false">
          <span class="desk-name">kiosk</span>
          <span class="desk-count mono" id="count-kiosk"></span>
        </button>
      </nav>

      <section id="desk-blog" class="desk-panel">
        <p class="note">
          Publishing sends a post to its author's followers, under the author's name.
          Every language of a slug goes out as one Article.
        </p>
        <ul id="posts" class="rows"><li class="empty">Loading…</li></ul>
      </section>

      <section id="desk-kiosk" class="desk-panel" hidden>
        <p class="note">
          Tags are put on by hand — nothing infers them. Type what a paper is about;
          the vocabulary settles by use.
        </p>
        <div class="controls">
          <div class="seg" role="group" aria-label="Which papers">
            <button type="button" class="seg-btn" data-scope="all" aria-pressed="true">
              All
            </button>
            <button type="button" class="seg-btn" data-scope="untagged" aria-pressed="false">
              Needs a tag
            </button>
          </div>
          <label class="pick">
            Tagged
            <select id="tag-filter" class="mono"><option value="">any</option></select>
          </label>
        </div>
        <ul id="papers" class="rows"><li class="empty">Loading…</li></ul>
        <button type="button" id="older" class="more" hidden>Older papers</button>
      </section>
    </div>

    <!-- Global, not scoped: both desks build their rows client-side (from
         /api/posts and /api/papers), and elements made by createElement never
         carry Astro's scoping attribute — so scoped rules would style the
         static shell and skip every button, tag and input inside it. Same
         reason kiosk's rack styles are global. -->
    <style is:global>
      /* The room reuses the family's paper and scale; what's its own is the
         density (this is a workbench, not a reading page) and one rule about
         colour, below. */
      :root {
        /* The house keeps no decorative accent — colour is functional. This
           room borrows the build lane's rust for a single meaning of its own:
           THIS LEAVES THE BUILDING. It is the only colour on the page, so the
           irreversible act is the one thing the eye lands on. */
        --color-out: var(--color-build);
        --mono:
          ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace;
      }

      .room {
        max-width: 46rem;
        margin: 0 auto;
        padding: var(--space-8) var(--space-4) var(--space-16);
      }

      /* Values you operate on — handles, dates, tags — are set apart from
         prose, because they're data rather than sentences. */
      .mono {
        font-family: var(--mono);
        font-size: 0.9em;
        font-variant-numeric: tabular-nums;
      }

      /* --- the room's header --- */

      .room-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: var(--space-4);
        flex-wrap: wrap;
        padding-bottom: var(--space-4);
        border-bottom: 1px solid var(--color-border);
      }

      .room-name {
        font-size: var(--text-xl);
        letter-spacing: -0.01em;
      }

      .room-who {
        display: flex;
        gap: var(--space-3);
        align-items: baseline;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .room-who a {
        color: var(--color-text-muted);
        text-underline-offset: 0.16em;
      }

      .room-who a:hover {
        color: var(--color-text);
      }

      /* --- the desks --- */

      .desks {
        display: flex;
        gap: var(--space-6);
        margin: var(--space-6) 0 var(--space-8);
      }

      .desk {
        display: flex;
        align-items: baseline;
        gap: var(--space-2);
        padding: 0;
        font: inherit;
        background: none;
        border: none;
        cursor: pointer;
        color: var(--color-text-muted);
      }

      .desk[aria-pressed='true'] {
        color: var(--color-text);
      }

      .desk-name {
        font-size: var(--text-lg);
        font-weight: 600;
      }

      /* The count is the desk's workload; it disappears at zero rather than
         showing a 0, so a quiet desk simply looks quiet. */
      .desk-count {
        padding: 0 var(--space-2);
        border: 1px solid var(--color-border-strong);
        border-radius: 999px;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .desk-count:empty {
        display: none;
      }

      .note {
        max-width: var(--measure);
        margin-bottom: var(--space-6);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .rows {
        list-style: none;
        padding: 0;
      }

      .empty {
        padding: var(--space-6) 0;
        color: var(--color-text-muted);
        font-size: var(--text-sm);
      }

      /* Something went wrong reads as ink against the muted text around it.
         It deliberately does NOT borrow the rust: that colour means "this
         leaves the building", and a failed fetch doesn't. */
      .empty.is-err {
        color: var(--color-text);
      }

      /* --- the blog desk: rows carry a publish edge --- */

      .post {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-4);
        /* room for the edge */
        padding: var(--space-4) 0 var(--space-4) var(--space-4);
        border-top: 1px solid var(--color-border);
        position: relative;
      }

      .post:first-child {
        border-top: none;
      }

      /* THE SIGNATURE. A post is either out in the world or it isn't, and that
         is the most important fact on this desk — so it's structural, not a
         word in the metadata. Scan the left column to see what has escaped. */
      .post::before {
        content: '';
        position: absolute;
        inset: var(--space-3) auto var(--space-3) 0;
        width: 3px;
        border-radius: 999px;
        background: transparent;
      }

      .post[data-out='true']::before {
        background: var(--color-out);
      }

      .post-title {
        font-weight: 600;
        line-height: 1.3;
        text-wrap: balance;
      }

      .post-meta {
        margin-top: var(--space-1);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .langs {
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      /* Publish is filled; Update is outlined. A first send and a re-send are
         not the same act, and the buttons shouldn't claim they are. */
      .act {
        flex: none;
        padding: var(--space-2) var(--space-4);
        font: inherit;
        font-size: var(--text-sm);
        border-radius: var(--radius);
        cursor: pointer;
      }

      .act-publish {
        color: var(--color-surface);
        background: var(--color-out);
        border: 1px solid var(--color-out);
      }

      .act-update {
        color: var(--color-text);
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
      }

      .act-publish:hover:not([disabled]) {
        filter: brightness(0.94);
      }

      .act-update:hover:not([disabled]) {
        border-color: var(--color-text);
      }

      .act[disabled] {
        opacity: 0.5;
        cursor: default;
      }

      .msg {
        display: block;
        margin-top: var(--space-1);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        text-align: right;
      }

      .msg.is-err {
        color: var(--color-text);
      }

      /* --- the kiosk desk: entirely in ink, because tagging undoes --- */

      .controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-4);
        flex-wrap: wrap;
        margin-bottom: var(--space-4);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .seg {
        display: flex;
        border: 1px solid var(--color-border-strong);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .seg-btn {
        padding: var(--space-1) var(--space-3);
        font: inherit;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        background: var(--color-surface);
        border: none;
        cursor: pointer;
      }

      .seg-btn + .seg-btn {
        border-left: 1px solid var(--color-border);
      }

      .seg-btn[aria-pressed='true'] {
        color: var(--color-surface);
        background: var(--color-text);
      }

      .pick {
        display: flex;
        align-items: center;
        gap: var(--space-2);
      }

      .pick select {
        font-family: var(--mono);
        font-size: var(--text-sm);
        padding: var(--space-1) var(--space-2);
        color: var(--color-text);
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: var(--radius);
      }

      .paper {
        padding: var(--space-4) 0;
        border-top: 1px solid var(--color-border);
      }

      .paper:first-child {
        border-top: none;
      }

      .paper-title {
        display: block;
        font-weight: 600;
        line-height: 1.3;
        color: var(--color-text);
        text-decoration: none;
        text-wrap: balance;
      }

      .paper-title:hover {
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .paper-meta {
        margin-top: var(--space-1);
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .tagrow {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--space-2);
        margin-top: var(--space-3);
      }

      .tag {
        display: inline-flex;
        align-items: center;
        gap: var(--space-1);
        padding: 0.1em 0.5em;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: var(--radius-sm);
        animation: tag-in 140ms ease-out;
      }

      @keyframes tag-in {
        from {
          opacity: 0;
          transform: translateY(2px);
        }
      }

      /* On the row, not yet acknowledged by the server. Faint rather than
         busy — a spinner would make a 60ms round trip look like an event. */
      .tag.is-pending {
        opacity: 0.5;
      }

      .tag-off {
        padding: 0;
        font: inherit;
        line-height: 1;
        color: var(--color-text-muted);
        background: none;
        border: none;
        cursor: pointer;
      }

      .tag-off:hover {
        color: var(--color-text);
      }

      .tag-entry {
        position: relative;
      }

      .tag-add {
        width: 9rem;
        padding: 0.15em 0.5em;
        font-family: var(--mono);
        font-size: 0.9em;
        color: var(--color-text);
        background: transparent;
        border: 1px dashed var(--color-border-strong);
        border-radius: var(--radius-sm);
      }

      .tag-add:hover,
      .tag-add:focus {
        background: var(--color-surface);
        border-style: solid;
      }

      .tag-add::placeholder {
        color: var(--color-text-muted);
      }

      /* Words already in use, offered as you type. The vocabulary is meant to
         settle by use, so seeing it is how that happens — an empty box shows
         the whole of it. */
      .suggest {
        position: absolute;
        z-index: 2;
        top: calc(100% + 2px);
        left: 0;
        min-width: 11rem;
        margin: 0;
        padding: var(--space-1);
        list-style: none;
        background: var(--color-surface);
        border: 1px solid var(--color-border-strong);
        border-radius: var(--radius);
      }

      .suggest-item {
        display: flex;
        justify-content: space-between;
        gap: var(--space-4);
        padding: 0.15em var(--space-2);
        border-radius: var(--radius-sm);
        cursor: pointer;
      }

      .suggest-item.is-active,
      .suggest-item:hover {
        color: var(--color-surface);
        background: var(--color-text);
      }

      /* How many papers already carry the word — the reason to reuse it. */
      .suggest-count {
        font-size: var(--text-sm);
        color: var(--color-text-muted);
      }

      .suggest-item.is-active .suggest-count,
      .suggest-item:hover .suggest-count {
        color: var(--color-border);
      }

      .more {
        margin-top: var(--space-6);
        padding: 0;
        font: inherit;
        font-size: var(--text-sm);
        color: var(--color-text-muted);
        background: none;
        border: none;
        cursor: pointer;
      }

      .more:hover {
        color: var(--color-text);
        text-decoration: underline;
      }

      :focus-visible {
        outline: 2px solid var(--color-text);
        outline-offset: 2px;
      }

      @media (prefers-reduced-motion: reduce) {
        .tag {
          animation: none;
        }
      }

      @media (max-width: 32rem) {
        .post {
          flex-direction: column;
          align-items: stretch;
        }

        .msg {
          text-align: left;
        }
      }
    </style>

    <script>
      // --- small helpers ---------------------------------------------------

      const el = (tag: string, cls?: string, text?: string) => {
        const n = document.createElement(tag);
        if (cls) n.className = cls;
        // Titles, authors and tags are remote text — they go in as text,
        // never as markup.
        if (text != null) n.textContent = text;
        return n;
      };

      async function api(path: string, init?: RequestInit) {
        const res = await fetch(path, init);
        const data = await res.json().catch(() => ({}) as any);
        if (!res.ok) throw new Error(data?.error || `failed (${res.status})`);
        return data;
      }

      const setCount = (id: string, n: number) => {
        document.getElementById(id)!.textContent = n > 0 ? String(n) : '';
      };

      // --- the blog desk ---------------------------------------------------

      async function loadPosts() {
        const list = document.getElementById('posts')!;
        let data: any;
        try {
          data = await api('/api/posts');
        } catch (e: any) {
          list.replaceChildren(el('li', 'empty is-err', e.message));
          return;
        }
        // Publishing goes out under an author's name, so it's worth seeing
        // whose hand is on the button.
        document.getElementById('who')!.textContent = data.publisher ?? '';

        // One row per slug — its languages federate together as one Article.
        const bySlug = new Map<string, any>();
        for (const p of data.posts) {
          const key = `${p.author}/${p.slug}`;
          if (!bySlug.has(key)) bySlug.set(key, { ...p, langs: [] });
          bySlug.get(key).langs.push(p.lang);
        }
        const rows = [...bySlug.values()].sort((a, b) =>
          String(b.date).localeCompare(String(a.date)),
        );
        setCount('count-blog', rows.filter((p) => !p.published).length);

        list.replaceChildren(
          ...(rows.length ? rows.map(postRow) : [el('li', 'empty', 'No posts yet.')]),
        );
      }

      function postRow(p: any) {
        const li = el('li', 'post');
        li.dataset.out = p.published ? 'true' : 'false';

        const left = el('div');
        left.append(el('p', 'post-title', p.title));
        const meta = el('p', 'post-meta');
        meta.append(el('span', 'mono', p.author));
        meta.append(' · ');
        meta.append(el('span', 'mono', String(p.date).slice(0, 10)));
        meta.append(' · ');
        meta.append(el('span', 'langs', p.langs.slice().sort().join(' ')));
        left.append(meta);

        const right = el('div');
        const action = p.published ? 'update' : 'create';
        const btn = el(
          'button',
          `act ${p.published ? 'act-update' : 'act-publish'}`,
          p.published ? 'Update' : 'Publish',
        ) as HTMLButtonElement;
        btn.type = 'button';
        const msg = el('span', 'msg');
        btn.addEventListener('click', async () => {
          btn.disabled = true;
          msg.className = 'msg';
          msg.textContent = p.published ? 'Updating…' : 'Publishing…';
          try {
            await api('/api/publish', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ lang: p.langs[0], slug: p.slug, action }),
            });
            // The button said Publish, so the result says Published.
            msg.textContent = p.published ? 'Updated' : 'Published';
            if (!p.published) {
              // It's out now: the edge fills in, and the desk's count drops.
              li.dataset.out = 'true';
              loadPosts();
            }
          } catch (e: any) {
            msg.textContent = e.message;
            msg.className = 'msg is-err';
            btn.disabled = false;
          }
        });
        right.append(btn, msg);

        li.append(left, right);
        return li;
      }

      // --- the kiosk desk --------------------------------------------------

      // The rack is paged by the published timestamp of the last row shown.
      let cursor: string | null = null;
      let scope: 'all' | 'untagged' = 'all';
      const PAGE = 24;

      function rackQuery(before: string | null) {
        const q = new URLSearchParams({ limit: String(PAGE) });
        if (before) q.set('before', before);
        if (scope === 'untagged') q.set('untagged', '1');
        const shelf = (document.getElementById('tag-filter') as HTMLSelectElement).value;
        if (shelf) q.set('tag', shelf);
        return `/api/papers?${q}`;
      }

      async function loadPapers(append = false) {
        const list = document.getElementById('papers')!;
        const older = document.getElementById('older') as HTMLButtonElement;
        if (!append) {
          cursor = null;
          list.replaceChildren(el('li', 'empty', 'Loading…'));
        }
        let papers: any[];
        try {
          papers = (await api(rackQuery(cursor))).papers;
        } catch (e: any) {
          list.replaceChildren(el('li', 'empty is-err', e.message));
          return;
        }
        const rows = papers.map(paperRow);
        if (append) {
          list.append(...rows);
        } else if (rows.length === 0) {
          // An empty screen is an invitation, or — here — a finished job.
          list.replaceChildren(
            el(
              'li',
              'empty',
              scope === 'untagged'
                ? 'Every paper on the rack has a tag.'
                : 'Nothing on the rack yet.',
            ),
          );
        } else {
          list.replaceChildren(...rows);
        }

        cursor = papers.length ? papers[papers.length - 1].published : null;
        older.hidden = papers.length < PAGE;
      }

      function paperRow(p: any) {
        const li = el('li', 'paper');

        const link = el('a', 'paper-title', p.title || p.url) as HTMLAnchorElement;
        link.href = p.url;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        li.append(link);

        const meta = el('p', 'paper-meta');
        meta.append(el('span', 'mono', p.author_name || p.author || ''));
        meta.append(' · ');
        meta.append(el('span', 'mono', String(p.published ?? '').slice(0, 10)));
        li.append(meta);

        // The row is never rebuilt — chips are added and removed one at a time.
        // Redrawing the whole thing re-ran every chip's entrance animation, so
        // putting one tag on made all of them flinch, and the eye had nowhere
        // to land.
        const row = el('div', 'tagrow');
        const tags = new Set<string>(p.tags ?? []);
        const entry = tagInput(p.iri, tags, row);
        for (const t of [...tags].sort()) row.append(tagChip(p.iri, t, tags, row).chip);
        row.append(entry);
        li.append(row);
        return li;
      }

      // One chip. It takes itself off the row when removed, and knows how to
      // settle from "just typed" into "stored".
      function tagChip(iri: string, tag: string, tags: Set<string>, row: HTMLElement) {
        const chip = el('span', 'tag mono');
        const label = el('span', undefined, tag);
        const off = el('button', 'tag-off', '×') as HTMLButtonElement;
        off.type = 'button';
        off.title = `Remove ${tag}`;
        off.addEventListener('click', async () => {
          // The chip goes at once; if the server refuses, it comes back.
          const at = chip.nextSibling;
          chip.remove();
          tags.delete(tag);
          try {
            await api('/api/tags', {
              method: 'DELETE',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ iri, tag }),
            });
            loadTags();
          } catch {
            tags.add(tag);
            row.insertBefore(chip, at);
          }
        });
        chip.append(label, off);
        return { chip, label };
      }

      function tagInput(iri: string, tags: Set<string>, row: HTMLElement) {
        const box = el('div', 'tag-entry');
        const input = el('input', 'tag-add') as HTMLInputElement;
        input.placeholder = 'add a tag';
        // Native autocomplete is turned off: the browser's own history of what
        // was typed here isn't the vocabulary — the tags in use are, and those
        // are offered below.
        input.autocomplete = 'off';
        input.setAttribute('role', 'combobox');
        input.setAttribute('aria-expanded', 'false');

        const menu = el('ul', 'suggest') as HTMLUListElement;
        menu.hidden = true;
        menu.setAttribute('role', 'listbox');

        let shown: { tag: string; count: number }[] = [];
        let active = -1;

        const close = () => {
          menu.hidden = true;
          active = -1;
          input.setAttribute('aria-expanded', 'false');
        };

        const render = () => {
          const q = input.value.trim().toLowerCase();
          shown = knownTags
            // A word already on this paper isn't worth offering again.
            .filter((t) => !tags.has(t.tag))
            .filter((t) => q === '' || t.tag.includes(q))
            .slice(0, 6);
          if (shown.length === 0) return close();
          menu.replaceChildren(
            ...shown.map((t, i) => {
              const li = el('li', `suggest-item${i === active ? ' is-active' : ''}`);
              li.setAttribute('role', 'option');
              li.setAttribute('aria-selected', String(i === active));
              li.append(el('span', 'mono', t.tag), el('span', 'suggest-count', String(t.count)));
              // mousedown, not click: the input's blur would close the menu
              // before a click ever landed.
              li.addEventListener('mousedown', (e) => {
                e.preventDefault();
                commit(t.tag);
              });
              return li;
            }),
          );
          menu.hidden = false;
          input.setAttribute('aria-expanded', 'true');
        };

        // The tag lands the moment it's typed. Waiting for the round trip made
        // the act feel either instant-and-flickery or dead-then-sudden,
        // depending only on the network — which is not something the hand
        // should have to feel. The server still decides; it just corrects a
        // chip that's already there.
        async function commit(value: string) {
          const typed = value.trim().replace(/\s+/g, ' ');
          if (!typed) return;
          close();
          input.value = '';
          // A guess at how it will be stored, only so a chip can appear now.
          // This is NOT the rule — normalizeTag in kiosk/tags.js is, and the
          // reply below overwrites this guess with whatever it actually says.
          const guess = typed.toLowerCase();
          if (tags.has(guess)) return; // already on this paper

          const { chip, label } = tagChip(iri, guess, tags, row);
          chip.classList.add('is-pending');
          row.insertBefore(chip, box);
          tags.add(guess);

          try {
            const { tag } = await api('/api/tags', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ iri, tag: typed }),
            });
            if (tag !== guess) {
              label.textContent = tag;
              tags.delete(guess);
              tags.add(tag);
            }
            chip.classList.remove('is-pending');
            // The menu was closed to get the chip out of the way, not because
            // the person is done — the cursor never left the box. Tagging runs
            // two or three words at a time, so the vocabulary comes back.
            if (document.activeElement === input) render();
            loadTags();
          } catch {
            // It never landed — take the chip back and hand the words over.
            chip.remove();
            tags.delete(guess);
            input.value = typed;
            input.select();
          }
        }

        input.addEventListener('input', () => {
          active = -1;
          render();
        });
        // An empty box shows the whole vocabulary — that's how it gets reused
        // rather than retyped slightly differently.
        input.addEventListener('focus', render);
        // Deferred so a mousedown on an option still gets its turn.
        input.addEventListener('blur', () => setTimeout(close, 0));

        input.addEventListener('keydown', (e) => {
          const key = (e as KeyboardEvent).key;
          if (key === 'ArrowDown' || key === 'ArrowUp') {
            e.preventDefault();
            if (menu.hidden) return render();
            active = Math.min(Math.max(active + (key === 'ArrowDown' ? 1 : -1), -1), shown.length - 1);
            render();
          } else if (key === 'Escape') {
            close();
          } else if (key === 'Enter') {
            e.preventDefault();
            // A highlighted suggestion wins; otherwise take what was typed —
            // a new word must always be able to get in.
            commit(active >= 0 ? shown[active].tag : input.value);
          }
        });

        box.append(input, menu);
        return box;
      }

      // The vocabulary in use, kept in hand so typing a tag filters it without
      // asking the server on every keystroke.
      let knownTags: { tag: string; count: number }[] = [];

      // The tags in use — the shelf list, the suggestions, and how much is left.
      async function loadTags() {
        let data: any;
        try {
          data = await api('/api/tags');
        } catch {
          return;
        }
        knownTags = data.tags ?? [];
        setCount('count-kiosk', data.untagged ?? 0);

        const select = document.getElementById('tag-filter') as HTMLSelectElement;
        const chosen = select.value;
        const any = el('option', undefined, 'any') as HTMLOptionElement;
        any.value = '';
        select.replaceChildren(
          any,
          ...data.tags.map((t: any) => {
            const o = el('option', undefined, `${t.tag} (${t.count})`) as HTMLOptionElement;
            o.value = t.tag;
            return o;
          }),
        );
        select.value = chosen;
      }

      // --- wiring ----------------------------------------------------------

      for (const tab of document.querySelectorAll<HTMLButtonElement>('.desk')) {
        tab.addEventListener('click', () => {
          for (const other of document.querySelectorAll('.desk')) {
            other.setAttribute('aria-pressed', String(other === tab));
          }
          document.getElementById('desk-blog')!.hidden = tab.dataset.desk !== 'blog';
          document.getElementById('desk-kiosk')!.hidden = tab.dataset.desk !== 'kiosk';
        });
      }

      for (const btn of document.querySelectorAll<HTMLButtonElement>('.seg-btn')) {
        btn.addEventListener('click', () => {
          for (const other of document.querySelectorAll('.seg-btn')) {
            other.setAttribute('aria-pressed', String(other === btn));
          }
          scope = btn.dataset.scope as 'all' | 'untagged';
          loadPapers();
        });
      }

      document.getElementById('tag-filter')!.addEventListener('change', () => loadPapers());
      document.getElementById('older')!.addEventListener('click', () => loadPapers(true));

      loadPosts();
      loadTags().then(() => loadPapers());
    </script>
  </body>
</html>
